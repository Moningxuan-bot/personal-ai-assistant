# 服务器配置
HOST=0.0.0.0
PORT=8000

# 数据库
DATABASE_URL=postgresql+asyncpg://aiuser:aipass@db:5432/aiassistant

# DeepSeek API
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 运行环境（development 放行弱 DEVICE_SECRET，production 强制检查）
APP_ENV=development

# 设备认证（生产环境必须改成强随机字符串！）
DEVICE_SECRET=local-dev-secret

# 记忆配置
MEMORY_RETRIEVAL_COUNT=5
